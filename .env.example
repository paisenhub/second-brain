# Google OAuth 2.0 — create at console.cloud.google.com
# Enable "Google+ API", set authorized redirect URI to CALLBACK_URL below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
CALLBACK_URL=http://localhost:3000/auth/google/callback

# Brain 1.0 — Gemini Flash API key from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Session secret — any long random string
SESSION_SECRET=change-this-to-a-long-random-string

# Port (default 3000)
PORT=3000
